/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co; frame-src 'self' https://www.openstreetmap.org;

/*.html
  Cache-Control: max-age=0, must-revalidate

/*.css
  Cache-Control: max-age=31536000, immutable

/*.js
  Cache-Control: max-age=31536000, immutable

/admin.html
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: private, no-store

/admin/*
  X-Robots-Tag: noindex, nofollow, noarchive
  Cache-Control: private, no-store

/404.html
  X-Robots-Tag: noindex
